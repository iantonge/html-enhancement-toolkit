  &lt;p id="detail">Old detail&lt;/p>

  &lt;a href="/reports/summary" het-target="main" het-select="summary">
    Refresh summary
  &lt;/a>
&lt;/main></textarea>
          <div class="editor-host" data-editor-host="html"></div>
        </div>

