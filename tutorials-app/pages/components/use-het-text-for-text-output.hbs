        <div class="mb-3">
          <label class="form-label fw-semibold" for="html-source">HTML</label>
          <textarea id="html-source" class="d-none" data-editor="html">&lt;section het-component="counter" het-seed="count=0">
  &lt;button type="button" het-on="click->count=count + 1">+&lt;/button>
  &lt;p het-text="count">&lt;/p>
&lt;/section></textarea>
          <div class="editor-host" data-editor-host="html"></div>
