  &lt;button type="button" het-on="click->toggleDetails">
    Toggle details
  &lt;/button>

  &lt;template het-if="details">
    &lt;article het-component="detailsPanel">
      &lt;p het-text="message">&lt;/p>
    &lt;/article>
  &lt;/template>
&lt;/section></textarea>
          <div class="editor-host" data-editor-host="html"></div>
