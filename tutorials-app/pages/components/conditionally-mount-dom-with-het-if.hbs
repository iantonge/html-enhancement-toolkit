        <div class="mb-3">
          <label class="form-label fw-semibold" for="js-source">JavaScript</label>
          <textarea id="js-source" class="d-none" data-editor="js">HET.registerComponent('detailsToggle', ({ signals }) => {
  signals.details = HET.signals.signal(null);

  return {
    toggleDetails() {
      signals.details.value = signals.details.value
        ? null
        : { message: HET.signals.signal('More details') };
    },
  };
});

HET.registerComponent('detailsPanel');
HET.init();</textarea>
