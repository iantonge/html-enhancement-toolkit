  &lt;form het-on="submit.prevent->submit">
    &lt;label>
      Search
      &lt;input
        type="search"
        het-seed="query=$props.value"
        het-on="input.debounce(300)->query=$target.value">
    &lt;/label>

    &lt;p het-text="query">&lt;/p>
    &lt;button type="submit">Search&lt;/button>
  &lt;/form>
&lt;/section></textarea>
