        <div class="mb-3">
          <label class="form-label fw-semibold" for="html-source">HTML</label>
          <textarea id="html-source" class="d-none" data-editor="html">&lt;section het-component="counter">
  &lt;button type="button" het-on="click->increment">+&lt;/button>
  &lt;p het-ref="countText">0&lt;/p>
&lt;/section></textarea>
          <div class="editor-host" data-editor-host="html"></div>
        </div>

        <div class="mb-3">
          <label class="form-label fw-semibold" for="js-source">JavaScript</label>
          <textarea id="js-source" class="d-none" data-editor="js">HET.registerComponent('counter', ({ refs, onCleanup }) => {
  const count = HET.signals.signal(0);

  const dispose = HET.signals.effect(() => {
    refs.countText.textContent = count.value;
  });

  onCleanup(dispose);

  return {
    increment() {
      count.value += 1;
    },
  };
});

HET.init();</textarea>
