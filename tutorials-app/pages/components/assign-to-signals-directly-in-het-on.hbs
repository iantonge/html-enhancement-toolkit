        <div class="mb-3">
          <label class="form-label fw-semibold" for="js-source">JavaScript</label>
          <textarea id="js-source" class="d-none" data-editor="js">HET.registerComponent('counter', ({ refs, signals, onCleanup }) => {
  signals.count = HET.signals.signal(0);

  const dispose = HET.signals.effect(() => {
    refs.countText.textContent = signals.count.value;
  });

  onCleanup(dispose);
});

HET.init();</textarea>
