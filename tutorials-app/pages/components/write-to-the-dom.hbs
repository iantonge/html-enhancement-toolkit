      </div>
      <nav class="d-flex justify-content-between gap-2 mb-3" aria-label="Tutorial section navigation">
          <a class="btn btn-outline-primary" href="/components/cleaning-up-resources">Previous</a>
          <a class="btn btn-outline-primary" href="/components/adding-local-state">Next</a>
