        <div class="mb-3">
          <label class="form-label fw-semibold" for="html-source">HTML</label>
          <textarea id="html-source" class="d-none" data-editor="html">&lt;section het-component="searchPage" het-exports="query"&gt;
  &lt;input type="search" value="Ada" het-model="query"&gt;

  &lt;aside het-component="searchSummary" het-imports="summaryQuery=query"&gt;
    &lt;p&gt;Current search: &lt;span het-text="summaryQuery"&gt;&lt;/span&gt;&lt;/p&gt;
  &lt;/aside&gt;
&lt;/section&gt;</textarea>
          <div class="editor-host" data-editor-host="html"></div>
