  &lt;button type="button" het-ref="alertButton">Alert&lt;/button>
&lt;/section></textarea>
          <div class="editor-host" data-editor-host="html"></div>
        </div>

        <div class="mb-3">
          <label class="form-label fw-semibold" for="js-source">JavaScript</label>
          <textarea id="js-source" class="d-none" data-editor="js">HET.registerComponent('alerter', ({ refs, onCleanup }) => {
  function handleClick() {
    alert('Clicked');
  }

  refs.alertButton.addEventListener('click', handleClick);

  onCleanup(() => {
    refs.alertButton.removeEventListener('click', handleClick);
  });
});

HET.init();</textarea>
