<section het-pane="main" het-nav class="card shadow-sm border-0">
  <div class="card-body">
    <h1 class="h4 mb-3">{{title}}</h1>
    <p id="primary">Initial primary history content.</p>
    <p id="secondary">Initial secondary history content.</p>
    <a
      id="select-also-link"
      class="btn btn-outline-secondary"
      href="/requests/history/responses/select-also"
      het-target="main"
      het-select="primary"
      het-also="sidebar"
    >
      Navigate with select + also
    </a>
  </div>
</section>
<aside id="sidebar" class="card shadow-sm border-0 mt-3">
  <div class="card-body">
    <p>Initial sidebar history content.</p>
  </div>
</aside>
