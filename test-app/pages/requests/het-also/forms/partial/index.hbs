<section het-pane="main" class="card shadow-sm border-0">
  <div class="card-body">
    <h1 class="h4 mb-3">{{title}}</h1>
    <p id="main-content" class="text-muted">Main content.</p>
    <form id="form" method="get" action="/requests/het-also/forms/responses/partial" het-target="main" het-also="sidebar">
      <button id="submit" type="submit" class="btn btn-outline-secondary">Update main + sidebar</button>
      <button id="clear-submit" type="submit" class="btn btn-outline-secondary" het-also="">Update main only</button>
    </form>
  </div>
</section>
<aside id="sidebar" class="card shadow-sm border-0 mt-3">
  <div class="card-body">
    <p>Sidebar content.</p>
  </div>
</aside>
