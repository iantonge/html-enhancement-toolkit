<section class="card shadow-sm border-0">
  <div class="card-body">
    <h1 class="h4 mb-3">{{title}}</h1>
    <div het-component="imports-alias-parent" het-exports="count">
      <button id="increment-alias" type="button" het-on="click=increment" class="btn btn-sm btn-primary">
        Increment
      </button>
      <div het-component="imports-alias-child" het-imports="childCount=count">
        <p id="alias-value" het-props="textContent=childCount" class="mb-0 mt-2 text-muted"></p>
      </div>
    </div>
  </div>
</section>
<script nonce="{{{cspNonce}}}">
  window.HET.registerComponent('imports-alias-parent', ({ signals }) => {
    signals.count = window.HET.signals.signal(0);
    return {
      increment() {
        signals.count.value += 1;
      },
    };
  });

  window.HET.registerComponent('imports-alias-child', ({ signals }) => {
    if (!signals.childCount) {
      throw new Error('HET test error: missing imported childCount');
    }
  });
</script>
