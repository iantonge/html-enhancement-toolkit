<section class="card shadow-sm border-0">
  <div class="card-body">
    <h1 class="h4 mb-3">{{title}}</h1>
    <div het-component="imports-conflict-parent" het-exports="count">
      <div het-component="imports-conflict-child" het-imports="count">
        <p het-props="textContent=count:seed">5</p>
      </div>
    </div>
  </div>
</section>
<script nonce="{{{cspNonce}}}">
  window.HET.registerComponent('imports-conflict-parent', ({ signals }) => {
    signals.count = window.HET.signals.signal(0);
  });

  window.HET.registerComponent('imports-conflict-child');
</script>
