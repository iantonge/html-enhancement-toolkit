<section class="card shadow-sm border-0">
  <div class="card-body">
    <h1 class="h4 mb-3">{{title}}</h1>
    <div het-component="het-on-assignment-missing-source">
      <button id="assignment-missing-source-button" type="button" het-on="click->count=$missing">
        Run
      </button>
    </div>
  </div>
</section>
<script nonce="{{{cspNonce}}}">
  window.HET.registerComponent('het-on-assignment-missing-source', ({ signals }) => {
    signals.count = window.HET.signals.signal(0);
  });
</script>
