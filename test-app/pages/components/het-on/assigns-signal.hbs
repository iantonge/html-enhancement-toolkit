<section class="card shadow-sm border-0">
  <div class="card-body">
    <h1 class="h4 mb-3">{{title}}</h1>
    <div het-component="het-on-assigns">
      <input
        id="assignment-input"
        value="5"
        class="form-control"
        het-on="input->count=$int($target.value); input->label='ready'; input->copy=label; input->status='done'; input->enabled=$bool('true')">
      <p id="assignment-count" het-text="count" class="mt-2 mb-0 text-muted"></p>
      <p id="assignment-label" het-text="label" class="mb-0 text-muted"></p>
      <p id="assignment-copy" het-text="copy" class="mb-0 text-muted"></p>
      <p id="assignment-status" het-text="status" class="mb-0 text-muted"></p>
      <p id="assignment-enabled" het-text="enabled" class="mb-0 text-muted"></p>
    </div>
  </div>
</section>
<script nonce="{{{cspNonce}}}">
  window.HET.registerComponent('het-on-assigns', ({ signals }) => {
    signals.count = window.HET.signals.signal(0);
    signals.label = window.HET.signals.signal('');
    signals.copy = window.HET.signals.signal('');
    signals.status = window.HET.signals.signal('');
    signals.enabled = window.HET.signals.signal(false);
  });
</script>
