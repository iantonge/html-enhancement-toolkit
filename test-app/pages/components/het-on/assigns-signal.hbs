<section class="card shadow-sm border-0">
  <div class="card-body">
    <h1 class="h4 mb-3">{{title}}</h1>
    <div het-component="het-on-assigns">
      <input
        id="assignment-input"
        value="5"
        data-label="ready"
        class="form-control"
        het-on="input->count=prop:value[int] input->label=attr:data-label input->copy=label input->status=literal:done input->enabled=literal:true[bool]">
      <button
        id="assignment-negate"
        type="button"
        class="btn btn-sm btn-primary mt-2"
        het-on="click->enabled=!enabled">
        Negate
      </button>
      <p id="assignment-count" het-props="textContent=count" class="mt-2 mb-0 text-muted"></p>
      <p id="assignment-label" het-props="textContent=label" class="mb-0 text-muted"></p>
      <p id="assignment-copy" het-props="textContent=copy" class="mb-0 text-muted"></p>
      <p id="assignment-status" het-props="textContent=status" class="mb-0 text-muted"></p>
      <p id="assignment-enabled" het-props="textContent=enabled" class="mb-0 text-muted"></p>
    </div>
  </div>
</section>
<script nonce="{{{cspNonce}}}">
  window.HET.registerComponent('het-on-assigns', ({ signals }) => {
    signals.count = window.HET.signals.signal(0);
    signals.label = window.HET.signals.signal('');
    signals.copy = window.HET.signals.signal('');
    signals.status = window.HET.signals.signal('');
    signals.enabled = window.HET.signals.signal(false);
  });
</script>
