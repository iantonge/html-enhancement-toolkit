<section class="card shadow-sm border-0">
  <div class="card-body">
    <h1 class="h4 mb-3">{{title}}</h1>
    <div het-component="het-model-checkbox-array">
      <div class="form-check">
        <input id="notify-email" type="checkbox" value="email" het-model="channels" class="form-check-input" checked>
        <label class="form-check-label" for="notify-email">Email</label>
      </div>
      <div class="form-check">
        <input id="notify-sms" type="checkbox" value="sms" het-model="channels" class="form-check-input">
        <label class="form-check-label" for="notify-sms">SMS</label>
      </div>
      <div class="form-check">
        <input id="notify-push" type="checkbox" value="push" het-model="channels" class="form-check-input">
        <label class="form-check-label" for="notify-push">Push</label>
      </div>
      <p id="channels-value" het-props="textContent=channels" class="mt-2 mb-0 text-muted"></p>
      <button id="set-channels" type="button" het-on="click->setChannels" class="btn btn-sm btn-primary mt-2">
        Set email and push from signal
      </button>
    </div>
  </div>
</section>
<script nonce="{{{cspNonce}}}">
  window.HET.registerComponent('het-model-checkbox-array', ({ signals }) => {
    return {
      setChannels() {
        signals.channels.value = ['email', 'push'];
      },
    };
  });
</script>

