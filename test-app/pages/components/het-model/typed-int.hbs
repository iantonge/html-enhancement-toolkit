<section class="card shadow-sm border-0">
  <div class="card-body">
    <h1 class="h4 mb-3">{{title}}</h1>
    <div het-component="het-model-typed-int">
      <input id="count-input" het-model:int="count" class="form-control" value="7">
      <p id="count-value" het-props="textContent=count" class="mt-2 mb-0 text-muted"></p>
      <button id="set-count" type="button" het-on="click->setCount" class="btn btn-sm btn-primary mt-2">
        Set from signal
      </button>
    </div>
  </div>
</section>
<script nonce="{{{cspNonce}}}">
  window.HET.registerComponent('het-model-typed-int', ({ signals }) => {
    return {
      setCount() {
        signals.count.value = 12;
      },
    };
  });
</script>
