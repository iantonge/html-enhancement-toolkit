<section class="card shadow-sm border-0">
  <div class="card-body">
    <h1 class="h4 mb-3">{{title}}</h1>
    <div het-component="acquisition-signal-reassignment"></div>
  </div>
</section>
<script nonce="{{{cspNonce}}}">
  window.HET.registerComponent('acquisition-signal-reassignment', ({ signals }) => {
    signals.count = window.HET.signals.signal(1);
    signals.count = window.HET.signals.signal(2);
  });
</script>
