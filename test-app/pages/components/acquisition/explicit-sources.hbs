<section class="card shadow-sm border-0">
  <div class="card-body">
    <h1 class="h4 mb-3">{{title}}</h1>
    <div het-component="acquisition-explicit-sources">
      <p id="text-source" het-seed="message=$text">Ready</p>
      <p id="text-output" het-text="message" class="mb-2"></p>

      <input id="prop-source" class="form-control" value="7" het-seed="count=$int($props.value)">
      <div id="mixed-source" het-seed="answer=$int(42)"></div>

      <p id="count-output" het-text="count" class="mb-0"></p>
      <p id="answer-output" het-text="answer" class="mb-0"></p>
    </div>
  </div>
</section>
<script nonce="{{{cspNonce}}}">
  window.HET.registerComponent('acquisition-explicit-sources');
</script>
