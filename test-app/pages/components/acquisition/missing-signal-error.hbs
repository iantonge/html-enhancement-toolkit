<section class="card">
  <div class="card-body">
    <div id="missing-signal-component" het-component="acquisition-missing-signal">
      Missing signal fixture
    </div>
  </div>
</section>

<script nonce="{{{cspNonce}}}">
  window.HET.registerComponent('acquisition-missing-signal', ({ signals }) => {
    signals.count = window.HET.signals.signal(1);
    signals.countt.value = 2;
  });
</script>
