<section class="card shadow-sm border-0">
  <div class="card-body">
    <h1 class="h4 mb-3">{{title}}</h1>
    <div id="sync-root" het-component="acquisition-sync">
      <input id="sync-input" class="form-control" het-sync="query=$props.value" value="alpha">
      <p id="sync-value" het-text="query" class="mt-2 mb-0 text-muted"></p>
    </div>
  </div>
</section>
<script nonce="{{{cspNonce}}}">
  window.HET.registerComponent('acquisition-sync');
</script>
