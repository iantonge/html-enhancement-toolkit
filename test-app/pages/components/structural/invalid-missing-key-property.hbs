<section class="card shadow-sm border-0" het-component="structural-missing-key-property">
  <div class="card-body">
    <h1 class="h4 mb-3">{{title}}</h1>
    <template het-for="items:id">
      <div het-component="structural-missing-key-property-item">
        <span het-text="label"></span>
      </div>
    </template>
  </div>
</section>

<script nonce="{{{cspNonce}}}">
  window.HET.registerComponent('structural-missing-key-property', ({ signals }) => {
    signals.items = window.HET.signals.signal([
      {
        label: window.HET.signals.signal('Missing key property'),
      },
    ]);
  });

  window.HET.registerComponent('structural-missing-key-property-item');
</script>
