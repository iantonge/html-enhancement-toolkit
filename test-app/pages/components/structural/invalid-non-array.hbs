<section class="card shadow-sm border-0" het-component="structural-invalid-array">
  <div class="card-body">
    <h1 class="h4 mb-3">{{title}}</h1>
    <template het-for="items">
      <div het-component="structural-invalid-array-item">
        <span het-text="label"></span>
      </div>
    </template>
  </div>
</section>

<script nonce="{{{cspNonce}}}">
  window.HET.registerComponent('structural-invalid-array', ({ signals }) => {
    signals.items = window.HET.signals.signal('not-an-array');
  });

  window.HET.registerComponent('structural-invalid-array-item');
</script>
