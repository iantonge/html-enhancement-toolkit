<section class="card shadow-sm border-0">
  <div class="card-body">
    <h1 class="h4 mb-3">{{title}}</h1>
    <div het-component="structural-shape-host">
      <ul id="shape-list" class="mb-3">
        <template het-for="items:id">
          <li het-component="structural-shape-item">
            <span class="shape-label" het-text="label"></span>
          </li>
        </template>
      </ul>
      <button id="shape-change" type="button" het-on="click->changeShape" class="btn btn-sm btn-primary">
        Change shape
      </button>
    </div>
  </div>
</section>
<script nonce="{{{cspNonce}}}">
  window.HET.registerComponent('structural-shape-host', ({ signals }) => {
    signals.items = window.HET.signals.signal([
      {
        id: 'shape',
        label: window.HET.signals.signal('Alpha'),
      },
    ]);

    return {
      changeShape() {
        signals.items.value = [
          {
            id: 'shape',
            label: window.HET.signals.signal('Beta'),
            extra: window.HET.signals.signal('Extra'),
          },
        ];
      },
    };
  });

  window.HET.registerComponent('structural-shape-item');
</script>
