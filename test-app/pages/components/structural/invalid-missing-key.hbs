<section class="card shadow-sm border-0" het-component="structural-missing-key">
  <div class="card-body">
    <h1 class="h4 mb-3">{{title}}</h1>
    <template het-for="items">
      <div het-component="structural-missing-key-item">
        <span het-text="label"></span>
      </div>
    </template>
  </div>
</section>

<script nonce="{{{cspNonce}}}">
  window.HET.registerComponent('structural-missing-key', ({ signals }) => {
    signals.items = window.HET.signals.signal([
      {
        id: 'missing-key',
        label: window.HET.signals.signal('Missing key'),
      },
    ]);
  });

  window.HET.registerComponent('structural-missing-key-item');
</script>
