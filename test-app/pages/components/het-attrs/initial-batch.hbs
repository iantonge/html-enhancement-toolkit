<script nonce="{{{cspNonce}}}">
  window.hetInitConfig = {
    ...window.hetInitConfig,
    batchInitialWrites: true,
    measureComponents: true,
  };
</script>

<section class="card shadow-sm border-0">
  <div class="card-body">
    <h1 class="h4 mb-3">{{title}}</h1>
    <div het-component="het-attrs-initial-batch">
      <p
        id="initial-batch-target"
        status="before"
        het-attrs="status=state">
        pending
      </p>
      <p
        id="initial-batch-coalesce"
        het-props="textContent=first; textContent=second">
        pending
      </p>
    </div>
  </div>
</section>

<script nonce="{{{cspNonce}}}">
  window.HET.registerComponent('het-attrs-initial-batch', ({ signals }) => {
    signals.state = window.HET.signals.signal('after');
    signals.first = window.HET.signals.signal('first');
    signals.second = window.HET.signals.signal('second');
  });
</script>
