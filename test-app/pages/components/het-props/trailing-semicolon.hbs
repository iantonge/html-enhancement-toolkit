<section class="card shadow-sm border-0">
  <div class="card-body">
    <h1 class="h4 mb-3">{{title}}</h1>
    <div het-component="het-props-trailing-semicolon">
      <p
        id="trailing-semicolon-output"
        het-props="textContent=count; title=count;"
      >pending</p>
    </div>
  </div>
</section>
<script nonce="{{{cspNonce}}}">
  window.HET.registerComponent('het-props-trailing-semicolon', ({ signals }) => {
    signals.count = window.HET.signals.signal(3);
  });
</script>
