<section id="main-pane" het-pane="main" class="card shadow-sm border-0">
  <div class="card-body">
    <h1 id="sync-title" class="h4 mb-3">{{title}}</h1>
    <div id="sync-component" het-component="integration-sync">
      <input id="sync-input" class="form-control" het-sync="query=$props.value" value="alpha">
      <p id="sync-value" het-props="textContent=query" class="mt-2 text-muted mb-3"></p>
      <input id="sync-flag" type="checkbox" het-sync="isActive=$bool($attrs.dataActive)" data-active="false">
      <span id="sync-indicator" het-bool-attrs="hidden=isActive">Inactive</span>
    </div>
    <a
      id="load-response"
      href="/integration/requests-components-sync/response"
      het-target="main"
      het-also="sync-sidebar"
      class="btn btn-sm btn-primary">
      Load sync response
    </a>
  </div>
</section>
<aside id="sync-sidebar" het-component="integration-sync" class="mt-3">
  <input id="sync-sidebar-input" class="form-control" het-sync="query=$props.value" value="aside alpha">
  <p id="sync-sidebar-value" het-props="textContent=query" class="mt-2 text-muted mb-0"></p>
</aside>
<script nonce="{{{cspNonce}}}">
  window.hetInitConfig = {
    replaceContent: (currentEl, replacementEl) => {
      Idiomorph.morph(currentEl, replacementEl);
      return currentEl;
    }
  };

  window.HET.registerComponent('integration-sync');
</script>
